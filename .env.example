# NVIDIA_API_KEY: Required for Nvidia Llama/Nemotron AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
NVIDIA_API_KEY=

# GEMINI_API_KEY: Server-side API Key for translation & backup chat counsel.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# VITE_API_URL: Set this on the frontend build to connect directly to your custom deployed Render backend.
# Example: VITE_API_URL="https://bhagwat-geeta-portal.onrender.com"
VITE_API_URL=
