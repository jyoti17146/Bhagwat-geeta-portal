# Port to run the backend on (Render default is 10000 or custom)
PORT=3000

# Server-side API keys for services
GEMINI_API_KEY=
NVIDIA_API_KEY=

# CORS Allowed Origins configuration to prevent CORS policy blocks.
# Put "*" to allow all origins, or comma-separated origins (no spaces)
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://bhagwat-geeta-portal.vercel.app
CORS_ALLOWED_ORIGINS=*
